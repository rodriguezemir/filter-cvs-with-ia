---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main
    class="flex min-h-screen w-full flex-col items-center justify-center bg-slate-950 px-6 py-20 text-center"
  >
    <span
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/60 px-4 py-1.5 text-sm text-slate-300 animate-bounce-fade-in"
    >
      <span class="h-2 w-2 rounded-full bg-rose-400"></span>
      Error 404
    </span>

    <h1
      class="text-4xl font-bold tracking-tight text-white sm:text-5xl animate-fade-in-up animate-delay-100"
    >
      Página no encontrada
    </h1>

    <p class="mt-4 max-w-md text-lg text-slate-400 animate-fade-in-up animate-delay-200">
      La página que buscas no existe o fue movida.
    </p>

    <a
      href="/"
      class="mt-10 inline-flex items-center gap-2 rounded-xl bg-indigo-500 px-6 py-3 text-sm font-semibold text-white transition-colors duration-200 hover:bg-indigo-400 animate-fade-in-up animate-delay-300"
    >
      Volver al inicio
    </a>
  </main>
</Layout>
