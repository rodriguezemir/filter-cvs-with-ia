---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="min-h-screen w-full bg-slate-950 px-6 py-12 text-slate-200">
    <div class="mx-auto max-w-6xl">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between animate-fade-in-down">
        <div>
          <h1 class="text-2xl font-bold text-white sm:text-3xl">Dashboard de candidatos</h1>
          <p class="mt-1 text-sm text-slate-500">
            Resultados del análisis de CVs con IA, ordenados por puntuación.
          </p>
        </div>
        <a
          href="/"
          class="inline-flex w-fit items-center gap-2 rounded-lg border border-slate-700 bg-slate-900/60 px-4 py-2 text-sm text-slate-300 transition-colors hover:border-indigo-400 hover:text-white"
        >
          + Analizar más CVs
        </a>
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden mt-24 flex flex-col items-center text-center animate-fade-in-up">
        <p class="text-lg font-medium text-slate-300">Todavía no hay resultados</p>
        <p class="mt-2 max-w-sm text-sm text-slate-500">
          Vuelve a la página principal, describe tu empresa y sube algunos CVs para ver el
          análisis aquí.
        </p>
        <a
          href="/"
          class="mt-6 rounded-xl bg-indigo-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-indigo-400"
        >
          Ir a analizar CVs
        </a>
      </div>

      <div id="dashboard-content" class="hidden">
        <!-- Stats -->
        <div id="stats-grid" class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-4"></div>

        <!-- Company description -->
        <div class="mt-8 rounded-2xl border border-slate-800 bg-slate-900/40 p-5">
          <p class="text-xs font-medium uppercase tracking-wide text-slate-500">
            Perfil de empresa / puesto
          </p>
          <p id="company-description-text" class="mt-2 text-sm text-slate-300"></p>
        </div>

        <!-- Errors -->
        <div
          id="errors-box"
          class="mt-8 hidden rounded-2xl border border-rose-900/50 bg-rose-950/30 p-5 animate-fade-in-up"
        >
          <p class="text-xs font-medium uppercase tracking-wide text-rose-400">
            Algunos CVs no se pudieron analizar
          </p>
          <ul id="errors-list" class="mt-2 list-disc space-y-1 pl-5 text-sm text-rose-300"></ul>
        </div>

        <!-- Candidates -->
        <div id="candidates-list" class="mt-8 flex flex-col gap-4"></div>
      </div>
    </div>
  </main>
</Layout>

<script>
  interface CvResult {
    fileName: string;
    candidateName: string;
    score: number;
    summary: string;
    strengths: string[];
    weaknesses: string[];
    recommendation: string;
  }

  interface AnalysisData {
    companyDescription: string;
    results: CvResult[];
    errors: string[];
  }

  const emptyState = document.getElementById("empty-state") as HTMLElement;
  const dashboardContent = document.getElementById("dashboard-content") as HTMLElement;
  const statsGrid = document.getElementById("stats-grid") as HTMLElement;
  const companyDescriptionText = document.getElementById(
    "company-description-text"
  ) as HTMLElement;
  const errorsBox = document.getElementById("errors-box") as HTMLElement;
  const errorsList = document.getElementById("errors-list") as HTMLElement;
  const candidatesList = document.getElementById("candidates-list") as HTMLElement;

  function scoreColor(score: number) {
    if (score >= 75) return { text: "text-emerald-400", ring: "border-emerald-500/40", bg: "bg-emerald-500/10" };
    if (score >= 50) return { text: "text-amber-400", ring: "border-amber-500/40", bg: "bg-amber-500/10" };
    return { text: "text-rose-400", ring: "border-rose-500/40", bg: "bg-rose-500/10" };
  }

  function recommendationBadge(recommendation: string) {
    const map: Record<string, string> = {
      "Fuertemente recomendado": "bg-emerald-500/15 text-emerald-400 border-emerald-500/30",
      "Recomendado": "bg-indigo-500/15 text-indigo-400 border-indigo-500/30",
      "Con reservas": "bg-amber-500/15 text-amber-400 border-amber-500/30",
      "No recomendado": "bg-rose-500/15 text-rose-400 border-rose-500/30",
    };
    return map[recommendation] ?? "bg-slate-500/15 text-slate-400 border-slate-500/30";
  }

  function renderStats(results: CvResult[]) {
    const total = results.length;
    const avg = total ? Math.round(results.reduce((sum, r) => sum + r.score, 0) / total) : 0;
    const strong = results.filter((r) => r.recommendation === "Fuertemente recomendado").length;
    const topScore = total ? Math.max(...results.map((r) => r.score)) : 0;

    const stats = [
      { label: "CVs analizados", value: String(total) },
      { label: "Puntuación media", value: `${avg}` },
      { label: "Mejor puntuación", value: `${topScore}` },
      { label: "Fuertemente recomendados", value: String(strong) },
    ];

    statsGrid.innerHTML = stats
      .map(
        (stat, index) => `
          <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-5 animate-fade-in-up animate-delay-${index * 100}">
            <p class="text-xs font-medium uppercase tracking-wide text-slate-500">${stat.label}</p>
            <p class="mt-2 text-2xl font-bold text-white">${stat.value}</p>
          </div>
        `
      )
      .join("");
  }

  function renderCandidates(results: CvResult[]) {
    if (results.length === 0) {
      candidatesList.innerHTML = `<p class="text-sm text-slate-500">No hay candidatos analizados.</p>`;
      return;
    }

    candidatesList.innerHTML = results
      .map((candidate, index) => {
        const colors = scoreColor(candidate.score);
        const delay = Math.min(index * 80, 800);
        return `
          <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-5 sm:p-6 animate-fade-in-up animate-delay-${delay}">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div class="flex items-start gap-4">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-slate-800 text-xs font-semibold text-slate-400">
                  #${index + 1}
                </div>
                <div>
                  <p class="font-semibold text-white">${candidate.candidateName}</p>
                  <p class="text-xs text-slate-500">${candidate.fileName}</p>
                  <span class="mt-2 inline-flex rounded-full border px-2.5 py-0.5 text-xs font-medium ${recommendationBadge(candidate.recommendation)}">
                    ${candidate.recommendation}
                  </span>
                </div>
              </div>
              <div class="flex shrink-0 items-center justify-center self-start rounded-full border ${colors.ring} ${colors.bg} px-4 py-2">
                <span class="text-xl font-bold ${colors.text}">${candidate.score}</span>
                <span class="ml-1 text-xs text-slate-500">/100</span>
              </div>
            </div>

            <p class="mt-4 text-sm text-slate-300">${candidate.summary}</p>

            <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
              <div>
                <p class="text-xs font-medium uppercase tracking-wide text-emerald-500">Fortalezas</p>
                <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-slate-400">
                  ${candidate.strengths.map((s) => `<li>${s}</li>`).join("")}
                </ul>
              </div>
              <div>
                <p class="text-xs font-medium uppercase tracking-wide text-rose-500">Debilidades</p>
                <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-slate-400">
                  ${candidate.weaknesses.map((w) => `<li>${w}</li>`).join("")}
                </ul>
              </div>
            </div>
          </div>
        `;
      })
      .join("");
  }

  function init() {
    const raw = sessionStorage.getItem("cv-analysis-results");

    if (!raw) {
      emptyState.classList.remove("hidden");
      return;
    }

    let data: AnalysisData;
    try {
      data = JSON.parse(raw);
    } catch {
      emptyState.classList.remove("hidden");
      return;
    }

    if (!data.results || data.results.length === 0) {
      emptyState.classList.remove("hidden");
      return;
    }

    dashboardContent.classList.remove("hidden");
    companyDescriptionText.textContent = data.companyDescription;
    renderStats(data.results);
    renderCandidates(data.results);

    if (data.errors && data.errors.length > 0) {
      errorsBox.classList.remove("hidden");
      errorsList.innerHTML = data.errors.map((e) => `<li>${e}</li>`).join("");
    }
  }

  init();
</script>
