---
---

<section
  class="relative flex min-h-screen w-full flex-col items-center justify-center overflow-hidden bg-slate-950 px-6 py-20"
>
  <!-- Background glow -->
  <div
    class="pointer-events-none absolute inset-0 [background:radial-gradient(60%_50%_at_50%_0%,rgba(99,102,241,0.25),transparent)]"
  >
  </div>

  <div class="relative z-10 mx-auto flex max-w-3xl flex-col items-center text-center">
    <span
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/60 px-4 py-1.5 text-sm text-slate-300"
    >
      <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
      Análisis de CVs con IA
    </span>

    <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl md:text-6xl">
      Filtra tus CVs en segundos
    </h1>

    <p class="mt-6 max-w-xl text-lg text-slate-400">
      Arrastra tus PDFs aquí y deja que la inteligencia artificial encuentre a
      los mejores candidatos por ti.
    </p>

    <!-- Dropzone -->
    <div class="mt-12 w-full">
      <label
        id="dropzone"
        for="pdf-input"
        class="group relative flex w-full cursor-pointer flex-col items-center justify-center rounded-2xl border-2 border-dashed border-slate-700 bg-slate-900/40 px-6 py-16 text-center transition-colors duration-200 hover:border-indigo-400 hover:bg-slate-900/70"
      >
        <input
          id="pdf-input"
          type="file"
          accept="application/pdf"
          multiple
          class="sr-only"
        />

        <div
          class="flex h-16 w-16 items-center justify-center rounded-full bg-indigo-500/10 text-indigo-400 transition-transform duration-200 group-hover:scale-110"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="h-8 w-8"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z"
            ></path>
          </svg>
        </div>

        <p class="mt-4 text-base font-medium text-slate-200">
          Arrastra tus PDFs aquí
        </p>
        <p class="mt-1 text-sm text-slate-500">
          o <span class="text-indigo-400 underline underline-offset-2">haz click para seleccionar</span> archivos
        </p>
        <p class="mt-4 text-xs text-slate-600">Solo archivos PDF</p>
      </label>

      <!-- Selected files list -->
      <ul
        id="file-list"
        class="mt-6 hidden w-full flex-col gap-2 text-left"
      >
      </ul>

      <button
        id="analyze-btn"
        type="button"
        disabled
        class="mt-8 hidden w-full items-center justify-center rounded-xl bg-indigo-500 px-6 py-3 text-sm font-semibold text-white transition-colors duration-200 hover:bg-indigo-400 disabled:cursor-not-allowed disabled:opacity-50 sm:w-auto sm:px-10"
      >
        Analizar CVs
      </button>
    </div>
  </div>
</section>

<script>
  const dropzone = document.getElementById("dropzone") as HTMLLabelElement;
  const input = document.getElementById("pdf-input") as HTMLInputElement;
  const fileList = document.getElementById("file-list") as HTMLUListElement;
  const analyzeBtn = document.getElementById(
    "analyze-btn"
  ) as HTMLButtonElement;

  let files: File[] = [];

  function formatSize(bytes: number) {
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
    return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
  }

  function render() {
    fileList.innerHTML = "";

    if (files.length === 0) {
      fileList.classList.add("hidden");
      fileList.classList.remove("flex");
      analyzeBtn.classList.add("hidden");
      analyzeBtn.classList.remove("flex");
      analyzeBtn.disabled = true;
      return;
    }

    fileList.classList.remove("hidden");
    fileList.classList.add("flex");
    analyzeBtn.classList.remove("hidden");
    analyzeBtn.classList.add("flex");
    analyzeBtn.disabled = false;

    files.forEach((file, index) => {
      const li = document.createElement("li");
      li.className =
        "flex items-center justify-between gap-3 rounded-lg border border-slate-800 bg-slate-900/60 px-4 py-3";

      li.innerHTML = `
        <div class="flex min-w-0 items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5 shrink-0 text-rose-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"></path>
          </svg>
          <span class="truncate text-sm text-slate-200">${file.name}</span>
        </div>
        <div class="flex shrink-0 items-center gap-3">
          <span class="text-xs text-slate-500">${formatSize(file.size)}</span>
          <button type="button" data-index="${index}" class="remove-file text-slate-500 transition-colors hover:text-rose-400" aria-label="Quitar archivo">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      `;

      fileList.appendChild(li);
    });

    fileList.querySelectorAll<HTMLButtonElement>(".remove-file").forEach((btn) => {
      btn.addEventListener("click", () => {
        const idx = Number(btn.dataset.index);
        files = files.filter((_, i) => i !== idx);
        render();
      });
    });
  }

  function addFiles(newFiles: FileList | File[]) {
    const pdfs = Array.from(newFiles).filter(
      (file) => file.type === "application/pdf"
    );
    const existingKeys = new Set(files.map((f) => `${f.name}-${f.size}`));
    const unique = pdfs.filter(
      (file) => !existingKeys.has(`${file.name}-${file.size}`)
    );
    files = [...files, ...unique];
    render();
  }

  input.addEventListener("change", () => {
    if (input.files) addFiles(input.files);
    input.value = "";
  });

  ["dragenter", "dragover"].forEach((eventName) => {
    dropzone.addEventListener(eventName, (event) => {
      event.preventDefault();
      dropzone.classList.add("border-indigo-400", "bg-slate-900/70");
    });
  });

  ["dragleave", "drop"].forEach((eventName) => {
    dropzone.addEventListener(eventName, (event) => {
      event.preventDefault();
      dropzone.classList.remove("border-indigo-400", "bg-slate-900/70");
    });
  });

  dropzone.addEventListener("drop", (event) => {
    const dropped = event.dataTransfer?.files;
    if (dropped) addFiles(dropped);
  });
</script>
